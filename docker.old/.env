#!/usr/bin/env bash

# See https://docs.docker.com/compose/environment-variables/#the-env-file

# Nginx
NGINX_HOST=localhost
NGINX_PORT=8000

# PHP

# See https://hub.docker.com/r/nanoninja/php-fpm/tags/
PHP_VERSION=latest

# PhpMyAdmin
PHP_MY_ADMIN_PORT=8080

# MySQL
MYSQL_STEOS_PORT=8989
MYSQL_STEOS_VERSION=8.4
MYSQL_STEOS_HOST=mysql
MYSQL_STEOS_DATABASE=steos
MYSQL_STEOS_ROOT_USER=root
MYSQL_STEOS_ROOT_PASSWORD=root
MYSQL_STEOS_USER=steos
MYSQL_STEOS_PASSWORD=steos
